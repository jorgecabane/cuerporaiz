# Base de datos (Prisma + Postgres, p. ej. Supabase)
# DATABASE_URL: conexión vía pooler (PgBouncer) — usada por la app para queries.
# DIRECT_DATABASE_URL: conexión directa al servidor — usada por migraciones y seed.
# Supabase: Project Settings → Database → Connection string. Pooler = puerto 6543, Direct = puerto 5432.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth: generar con: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="http://localhost:3000"
# Alias opcionales
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=

# Seed (opcional)
# SEED_ADMIN_EMAIL=admin@cuerporaiz.cl
# SEED_ADMIN_PASSWORD=

# MercadoPago (OAuth por centro; cada centro conecta su cuenta desde Panel → Plugins → Mercado Pago)
# MP_APP_ID=xxx  (Client ID de la aplicación en developers.mercadopago.com)
# MP_CLIENT_SECRET=xxx
# Redirect URI en la app MP: https://tudominio.com/api/admin/mercadopago/oauth/callback
# Ver docs/plugins/mercadopago-credenciales.md

# Zoom (OAuth por centro; cada centro conecta su cuenta desde Panel → Plugins → Zoom)
# ZOOM_CLIENT_ID=xxx
# ZOOM_CLIENT_SECRET=xxx
# Redirect URI en Zoom App: https://tudominio.com/api/admin/zoom/oauth/callback

# Google Meet (OAuth por centro; cada centro conecta su cuenta desde Panel → Plugins → Google Meet)
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx
# Redirect URI en Google Cloud: https://tudominio.com/api/admin/google-meet/oauth/callback
# Scope: https://www.googleapis.com/auth/calendar.events

# Email (Resend)
RESEND_API_KEY=
# Remitente: "Nombre <email@dominio.com>". En dev podés usar onboarding@resend.dev si el dominio está verificado en Resend.
EMAIL_FROM="Cuerpo Raíz <onboarding@resend.dev>"

# Email público de soporte (T&C / Privacy / Footer)
# Default si no se define: cuerporaiztrinidad@gmail.com
NEXT_PUBLIC_SUPPORT_EMAIL="cuerporaiztrinidad@gmail.com"

# Centro por defecto para el sitio público (NEXT_PUBLIC_ para que esté disponible en client components)
NEXT_PUBLIC_DEFAULT_CENTER_SLUG=cuerporaiz

# URL absoluta del sitio en producción. Se usa como metadataBase para Open Graph / Twitter Cards
# (las imágenes y URLs canónicas se resuelven contra esta base cuando alguien comparte un link).
# En previews de Vercel cae automáticamente a VERCEL_URL si esta variable no está seteada.
NEXT_PUBLIC_SITE_URL=https://cuerporaiz.cl

# Verificación de email: "true" (default) muestra banner de verificación, "false" lo desactiva (útil en dev)
REQUIRE_EMAIL_VERIFICATION=true

# Google OAuth (Sign in with Google — distinto de Google Meet por centro)
# Crear en console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URI: https://tudominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sanity CMS (blog). Si no se configuran, las rutas /blog y /studio devuelven 404.
# Crear proyecto en sanity.io → Project ID en manage.sanity.io.
# Ver docs/sanity-setup.md para pasos completos.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Opcional: fija una versión de API (recomendado). Si no, usa la del día.
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-23
# Token con permisos de lectura para draft mode (manage.sanity.io → API → Tokens → Viewer).
SANITY_API_READ_TOKEN=
# Secret para validar el endpoint /api/draft. Generar con: openssl rand -hex 32
SANITY_PREVIEW_SECRET=
