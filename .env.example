# ─────────────────────────────────────────────────────────────────────────────
# Base de datos (Prisma + Postgres, p. ej. Supabase)
# DATABASE_URL: conexión vía pooler (PgBouncer) — usada por la app para queries.
# DIRECT_DATABASE_URL: conexión directa al servidor — usada por migraciones y seed.
# Supabase: Project Settings → Database → Connection string. Pooler = puerto 6543, Direct = puerto 5432.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────────
# NextAuth — sesión + login. Generar AUTH_SECRET con: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="http://localhost:3000"
# Aliases retro-compatibles. Algunos callers leen NEXTAUTH_URL en runtime;
# manténelos sincronizados con AUTH_URL/AUTH_SECRET.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=

# Aliases extra de la URL base usados por correos y redirects. Si no se setean,
# el helper getBaseUrl() cae a NEXTAUTH_URL → NEXT_PUBLIC_APP_URL → NEXT_PUBLIC_BASE_URL → localhost:3000.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Verificación de email: "true" (default) muestra banner de verificación, "false" lo desactiva (útil en dev).
REQUIRE_EMAIL_VERIFICATION=true

# Google OAuth (Sign in with Google y Google Meet plugin — ambos comparten credenciales)
# Crear en console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Redirect URIs:
#   - https://tudominio.com/api/auth/callback/google           (login)
#   - https://tudominio.com/api/admin/google-meet/oauth/callback (plugin Meet)
# Scope adicional para Meet: https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Cron jobs (Vercel)
# Token compartido entre Vercel y la app. Generar con: openssl rand -hex 32
# Sin esto, los cron de plan-expiring y class-reminder responden 401.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Email (Resend)
RESEND_API_KEY=
# Remitente: "Nombre <email@dominio.com>". En dev podés usar onboarding@resend.dev si el dominio está verificado en Resend.
EMAIL_FROM="Cuerpo Raíz <onboarding@resend.dev>"

# Email público de soporte (T&C / Privacy / Footer / fallback de transferencia rechazada)
# Default si no se define: cuerporaiztrinidad@gmail.com
NEXT_PUBLIC_SUPPORT_EMAIL="cuerporaiztrinidad@gmail.com"

# Destinatario de alertas críticas de seguridad (webhook mismatch, firma inválida,
# etc.). Si no se setea, los eventos se loggean pero NO se envían.
SECURITY_ALERT_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Centro por defecto del sitio público (NEXT_PUBLIC_ para client components)
NEXT_PUBLIC_DEFAULT_CENTER_SLUG=cuerporaiz

# URL absoluta del sitio en producción. Se usa como metadataBase para Open Graph / Twitter Cards
# (las imágenes y URLs canónicas se resuelven contra esta base cuando alguien comparte un link).
# En previews de Vercel cae automáticamente a VERCEL_URL si esta variable no está seteada.
NEXT_PUBLIC_SITE_URL=https://cuerporaiz.cl

# ─────────────────────────────────────────────────────────────────────────────
# MercadoPago (OAuth por centro; cada centro conecta su cuenta desde Panel → Plugins → Mercado Pago)
# Sin estas variables el panel muestra "OAuth no disponible" en el plugin.
# Crear app en developers.mercadopago.com → Mis aplicaciones → Credenciales.
# Redirect URI en la app MP: https://tudominio.com/api/admin/mercadopago/oauth/callback
# Ver docs/plugins/mercadopago-credenciales.md
MP_APP_ID=
MP_CLIENT_SECRET=
# Toggles de prueba (opcionales). MP_TEST_MODE=true fuerza tokens TEST- aunque el secret sea de prod.
# MP_TEST_BUYER_EMAIL fija un email de comprador de pruebas para checkouts de suscripción.
# MP_TEST_MODE=false
# MP_TEST_BUYER_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Zoom (OAuth por centro; cada centro conecta su cuenta desde Panel → Plugins → Zoom)
# Crear app en marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth o User-managed.
# Redirect URI: https://tudominio.com/api/admin/zoom/oauth/callback
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Sanity CMS (blog). Si no se configuran, las rutas /blog y /studio devuelven 404.
# Crear proyecto en sanity.io → Project ID en manage.sanity.io.
# Ver docs/sanity-setup.md para pasos completos.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Opcional: fija una versión de API (recomendado). Si no, usa la del día.
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-23
# Token con permisos de lectura para draft mode (manage.sanity.io → API → Tokens → Viewer).
SANITY_API_READ_TOKEN=
# Token con permisos de escritura para subir imágenes desde el panel (manage.sanity.io → API → Tokens → Editor).
SANITY_API_WRITE_TOKEN=
# Secret para validar el endpoint /api/draft. Generar con: openssl rand -hex 32
SANITY_PREVIEW_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Seed local (opcional). Si se setean, prisma/seed.ts crea un admin con esas credenciales.
# SEED_ADMIN_EMAIL=admin@cuerporaiz.cl
# SEED_ADMIN_PASSWORD=
