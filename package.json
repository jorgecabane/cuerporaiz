    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sanity/client": "^7.21.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-sanity": "^12.3.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
