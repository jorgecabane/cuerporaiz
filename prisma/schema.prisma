// CuerpoRaíz — DB: Postgres (Supabase). Conexión vía DATABASE_URL.
// https://pris.ly/d/prisma-schema

// Generamos en la salida por defecto (node_modules). No usar output custom:
// cuando el cliente se generaba en lib/generated/prisma, la IDE/OS creaban copias
// "archivo 2.ts" al regenerar, y TypeScript las incluía → build colgado y cientos de errores.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Tenants (centros) ─────────────────────────────────────────────────────
model Center {
  id                             String   @id @default(cuid())
  name                           String
  slug                           String   @unique
  currency                       String   @default("CLP") // moneda del centro (localidad); usada en planes
  timezone                       String   @default("America/Santiago") // IANA tz para mostrar fechas en correos / UI cliente
  // Políticas del centro (tenant)
  cancelBeforeMinutes            Int      @default(720) // anticipación mínima (min) para cancelar sin consumir clase (720 = 12 h)
  maxNoShowsPerMonth             Int      @default(2) // no-shows máximos antes de advertencia/bloqueo
  bookBeforeMinutes              Int      @default(1440) // ventana para reservar: minutos antes del inicio deben quedar libres (1440 = 24 h)
  notifyWhenSlotFreed            Boolean  @default(true) // avisar cuando se libera un cupo
  instructorCanReserveForStudent Boolean  @default(true) // profesora puede reservar en nombre de alumna
  allowTrialClassPerPerson       Boolean  @default(true) // una clase de prueba por persona
  calendarStartHour              Int      @default(7) // hora de inicio del calendario semanal
  calendarEndHour                Int      @default(22) // hora de fin del calendario semanal
  calendarWeekStartDay           Int      @default(1) // 0=domingo, 1=lunes (ISO)
  defaultClassDurationMinutes    Int      @default(60)
  // Transferencia bancaria (plugin de pago)
  bankTransferEnabled            Boolean  @default(false)
  bankName                       String?
  bankAccountType                String?
  bankAccountNumber              String?
  bankAccountHolder              String?
  bankAccountRut                 String?
  bankAccountEmail               String?
  // Toggles secundarios del plugin (qué se puede pagar por transferencia)
  bankTransferAcceptPlans        Boolean  @default(true)
  bankTransferAcceptEvents       Boolean  @default(false)
  bankTransferRequireReceipt     Boolean  @default(true)
  // Fragmento opcional que el admin añade al correo de bienvenida del alumno
  welcomeEmailCustomBody         String?  @default("")
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  memberships            UserCenterRole[]
  liveClasses            LiveClass[]
  disciplines            Discipline[]
  liveClassSeries        LiveClassSeries[]
  holidays               CenterHoliday[]
  mercadopagoConfig      CenterMercadoPagoConfig?
  zoomConfig             CenterZoomConfig?
  googleMeetConfig       CenterGoogleMeetConfig?
  plans                  Plan[]
  orders                 Order[]
  webhookEvents          MercadoPagoWebhookEvent[]
  userPlans              UserPlan[]
  manualPayments         ManualPayment[]
  instructorBankAccounts InstructorBankAccount[]
  subscriptions          Subscription[]
  emailPreferences       EmailPreference[]
  siteConfig             CenterSiteConfig?
  siteSections           CenterSiteSection[]
  aboutPage              CenterAboutPage?
  onDemandCategories     OnDemandCategory[]
  lessonUnlocks          LessonUnlock[]
  events                 Event[]
  waitlistEntries        WaitlistEntry[]
}

// ─── Usuarios (sin datos de infra; dominio puro en lib/domain) ──────────────
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String?
  lastName        String?
  /**
   * URL de imagen de perfil (avatar)
   */
  imageUrl        String?
  phone           String?
  rut             String?
  birthday        DateTime?
  sex             String? // M, F, X, null
  notes           String? // observaciones internas del centro
  googleId        String?   @unique
  emailVerifiedAt DateTime?
  tokenVersion    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships             UserCenterRole[]
  reservations            Reservation[]
  orders                  Order[]
  userPlans               UserPlan[]
  manualPayments          ManualPayment[]
  instructorBankAccounts  InstructorBankAccount[]
  subscriptions           Subscription[]
  emailPreferences        EmailPreference[]
  siteItems               CenterSiteSectionItem[]
  lessonUnlocks           LessonUnlock[]
  eventTickets            EventTicket[]
  waitlistEntries         WaitlistEntry[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

// ─── Disciplinas (prácticas: Yoga, Pilates, TRX…) ─────────────────────────
model Discipline {
  id        String   @id @default(cuid())
  centerId  String
  name      String
  color     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  center      Center            @relation(fields: [centerId], references: [id], onDelete: Cascade)
  liveClasses LiveClass[]
  series      LiveClassSeries[]

  @@unique([centerId, name])
  @@index([centerId])
}

// ─── Regla de recurrencia para series de clases ────────────────────────────
enum RepeatFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model LiveClassSeries {
  id                 String          @id @default(cuid())
  centerId           String
  title              String
  disciplineId       String?
  instructorId       String?
  maxCapacity        Int             @default(20)
  durationMinutes    Int             @default(60)
  isOnline           Boolean         @default(false)
  meetingUrl         String?
  acceptsTrialReservations Boolean    @default(false)
  trialCapacity      Int?
  color              String?
  classPassEnabled   Boolean         @default(false)
  classPassCapacity  Int?
  repeatFrequency    RepeatFrequency @default(WEEKLY)
  repeatOnDaysOfWeek Int[]           @default([]) // 0=Dom, 1=Lun..6=Sáb
  repeatEveryN       Int             @default(1) // cada N semanas/días/meses
  startsAt           DateTime // fecha/hora de la primera clase
  endsAt             DateTime? // fecha fin de la serie (nullable = nunca)
  repeatCount        Int? // o N repeticiones (nullable = infinito/hasta endsAt)
  monthlyMode        String? // "dayOfMonth" | "weekdayOrdinal" (solo para MONTHLY)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  center     Center      @relation(fields: [centerId], references: [id], onDelete: Cascade)
  discipline Discipline? @relation(fields: [disciplineId], references: [id], onDelete: SetNull)
  instances  LiveClass[]

  @@index([centerId])
}

// ─── Clases en vivo (por centro) ───────────────────────────────────────────
model LiveClass {
  id                String   @id @default(cuid())
  centerId          String
  title             String
  startsAt          DateTime
  durationMinutes   Int      @default(60)
  maxCapacity       Int      @default(20)
  disciplineId      String?
  instructorId      String?
  isOnline          Boolean  @default(false)
  meetingUrl        String?
  acceptsTrialReservations Boolean @default(false)
  trialCapacity     Int?
  color             String?
  classPassEnabled  Boolean  @default(false)
  classPassCapacity Int?
  seriesId          String?
  // Serie de origen cuando la instancia se desvinculó (editar "solo esta"):
  // seriesId queda null, pero conservamos el origen para avisar al editar la serie.
  detachedFromSeriesId String?
  status            String   @default("ACTIVE") // ACTIVE | CANCELLED | ARCHIVED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  center          Center           @relation(fields: [centerId], references: [id], onDelete: Cascade)
  discipline      Discipline?      @relation(fields: [disciplineId], references: [id], onDelete: SetNull)
  series          LiveClassSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]

  @@index([centerId])
  @@index([centerId, startsAt])
  @@index([startsAt])
  @@index([disciplineId])
  @@index([seriesId])
  @@index([detachedFromSeriesId])
}

// ─── Feriados / días sin actividad por centro ──────────────────────────────
model CenterHoliday {
  id        String   @id @default(cuid())
  centerId  String
  date      DateTime @db.Date
  label     String?
  createdAt DateTime @default(now())

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([centerId, date])
  @@index([centerId])
}

// ─── Plan activo de un usuario (vincula User + Plan + Order) ────────────────
enum UserPlanStatus {
  ACTIVE
  EXPIRED
  FROZEN
  CANCELLED
}

enum PlanPaymentStatus {
  PENDING
  PARTIAL
  PAID
}

model UserPlan {
  id             String            @id @default(cuid())
  userId         String
  planId         String
  centerId       String
  orderId        String? @unique // null si fue asignado manualmente; UNIQUE previene minteo duplicado por race en webhook
  subscriptionId String? // null = pago único; set = plan recurrente (suscripción MP)
  status         UserPlanStatus    @default(ACTIVE)
  paymentStatus  PlanPaymentStatus @default(PENDING)
  classesTotal   Int? // null = ilimitado
  classesUsed    Int               @default(0)
  validFrom      DateTime          @default(now())
  validUntil     DateTime? // null = sin vencimiento explícito
  frozenAt       DateTime?
  frozenUntil    DateTime?
  freezeReason   String?
  unfrozenAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           Plan            @relation(fields: [planId], references: [id], onDelete: Restrict)
  center         Center          @relation(fields: [centerId], references: [id], onDelete: Cascade)
  subscription   Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  reservations   Reservation[]
  manualPayments ManualPayment[]
  lessonUnlocks  LessonUnlock[]

  @@index([userId, centerId])
  @@index([userId, centerId, status])
  @@index([centerId])
  @@index([status])
  @@index([subscriptionId])
}

// Pagos manuales: pueden ser de un UserPlan (cuota, transferencia) o sueltos (registro contable)
model ManualPayment {
  id              String   @id @default(cuid())
  centerId        String
  userId          String
  userPlanId      String? // null = pago suelto no vinculado a plan
  eventTicketId   String? // para transferencias de eventos aprobadas manualmente
  amountCents     Int
  currency        String   @default("CLP")
  method          String   @default("transfer") // transfer, cash, other
  note            String? // ej: "Cuota 1/3 Plan A", "Pago extra mat"
  receiptSanityId String? // doc id en Sanity con el comprobante (si aplica)
  paidAt          DateTime @default(now())
  createdAt       DateTime @default(now())

  center      Center       @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userPlan    UserPlan?    @relation(fields: [userPlanId], references: [id], onDelete: SetNull)
  eventTicket EventTicket? @relation(fields: [eventTicketId], references: [id], onDelete: SetNull)

  @@index([centerId])
  @@index([userId])
  @@index([userPlanId])
  @@index([eventTicketId])
}

// Datos bancarios por instructora (depósitos), por centro.
model InstructorBankAccount {
  id String @id @default(cuid())

  centerId String
  userId   String

  bankName          String?
  bankAccountType   String?
  bankAccountNumber String?
  bankAccountHolder String?
  bankAccountRut    String?
  bankAccountEmail  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([centerId, userId])
  @@index([centerId])
  @@index([userId])
}

// Estados de reserva
enum ReservationStatus {
  CONFIRMED // Confirmada
  CANCELLED // Cancelada a tiempo (clase devuelta al plan)
  LATE_CANCELLED // Cancelada tarde (clase consumida)
  ATTENDED // Asistió
  NO_SHOW // No asistió
}

model Reservation {
  id             String            @id @default(cuid())
  userId         String
  liveClassId    String
  userPlanId     String? // plan con el que se hizo la reserva (null = sin plan; ver isTrial)
  /// true cuando la reserva consumió el cupo de clase de prueba del usuario
  /// (alumno nuevo sin plan en clase con acceptsTrialReservations=true).
  /// Una clase puede admitir trials Y tener alumnos con plan en simultáneo;
  /// este flag distingue una reserva trial específica del resto.
  isTrial        Boolean           @default(false)
  status         ReservationStatus @default(CONFIRMED)
  /**
   * Marca cuándo se mandó el recordatorio "2h antes". Null = aún no enviado.
   * Hace idempotente al cron de class-reminder (necesario en Hobby por la
   * precisión ±59min de los schedules diarios).
   */
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  userPlan  UserPlan? @relation(fields: [userPlanId], references: [id], onDelete: SetNull)

  @@unique([userId, liveClassId])
  @@index([userId])
  @@index([liveClassId])
  @@index([userPlanId])
  @@index([userId, updatedAt])
  @@index([userId, isTrial])
}

// Lista de espera para clases y eventos. Polimórfica: exactamente uno de
// liveClassId o eventId está seteado (validado en lib/domain/waitlist.ts).
enum WaitlistStatus {
  QUEUED // en cola, sin notificar
  NOTIFIED // recibió correo broadcast (sigue en cola)
  HELD // solo eventos: hold activo durante checkout (consume cupo)
  PROMOTED // ganó el cupo y reservó/pagó (terminal)
  EXPIRED // hold venció, clase pasó, etc. (terminal)
  CANCELLED // salió manualmente o admin lo quitó (terminal)
}

model WaitlistEntry {
  id          String         @id @default(cuid())
  userId      String
  centerId    String // denormalizado para queries multi-tenant rápidas
  liveClassId String?
  eventId     String?
  status      WaitlistStatus @default(QUEUED)
  position    Int // orden FIFO al unirse
  notifiedAt  DateTime? // último broadcast recibido (para throttle)
  heldUntil   DateTime? // solo eventos: expiración del hold
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  center    Center     @relation(fields: [centerId], references: [id], onDelete: Cascade)
  liveClass LiveClass? @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  event     Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, liveClassId])
  @@unique([userId, eventId])
  @@index([liveClassId, status])
  @@index([eventId, status])
  // FIFO ordering: notifyWaitlistOnSpotFreed y listados ordenan por position.
  @@index([liveClassId, position])
  @@index([eventId, position])
  @@index([centerId])
  @@index([userId])
}

// Rol por centro (multi-tenant RBAC). Valores en inglés para consistencia con BD.
enum Role {
  ADMINISTRATOR
  INSTRUCTOR
  STUDENT
}

model UserCenterRole {
  id             String   @id @default(cuid())
  userId         String
  centerId       String
  role           Role
  // Cliente migrado desde otra plataforma: no recibe clase de prueba gratis en este centro.
  isLegacyClient Boolean  @default(false)
  createdAt      DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([userId, centerId])
  @@index([userId])
  @@index([centerId])
  @@index([centerId, role])
}

// ─── MercadoPago por centro (plugin activo + credenciales) ──────────────────
// Nota: el secret del webhook es global (`MP_WEBHOOK_SECRET` env), no por centro.
// `webhookSecret` quedó como columna deprecada y se eliminará en una migración futura.
model CenterMercadoPagoConfig {
  id              String    @id @default(cuid())
  centerId        String    @unique
  accessToken     String
  refreshToken    String?
  mpUserId        String?   @unique
  publicKey       String?
  webhookSecret   String?
  tokenExpiresAt  DateTime?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

// ─── Zoom por centro (plugin videollamadas) ──────────────────────────────────
model CenterZoomConfig {
  id             String    @id @default(cuid())
  centerId       String    @unique
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

// ─── Google Meet por centro (plugin videollamadas) ──────────────────────────
model CenterGoogleMeetConfig {
  id             String    @id @default(cuid())
  centerId       String    @unique
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

// Live = con profe en vivo (físico o online). On-demand = grabado. Membresía = acceso videoteca.
// PACK y MEMBERSHIP se mantienen por compatibilidad con datos existentes (mapear a LIVE y MEMBERSHIP_ON_DEMAND en app).
enum PlanType {
  PACK
  MEMBERSHIP
  LIVE
  ON_DEMAND
  MEMBERSHIP_ON_DEMAND
}

// Modalidad de cobro
enum BillingMode {
  ONE_TIME
  RECURRING
  BOTH
}

// Vigencia por período (1 período = mensual, trimestral, etc.)
enum ValidityPeriod {
  MONTHLY // mensual
  QUARTERLY // trimestral
  QUADRIMESTRAL // cuatrimestral
  SEMESTER // semestral
  ANNUAL // anual
}

model Plan {
  id                       String          @id @default(cuid())
  centerId                 String
  name                     String
  slug                     String
  description              String?
  amountCents              Int
  currency                 String          @default("CLP")
  type                     PlanType
  // Vigencia: solo uno de los dos (por días O por período)
  validityDays             Int? // vigencia por días (ej. 15 días)
  validityPeriod           ValidityPeriod? // vigencia por período (1 mensual, 1 trimestral, etc.)
  billingMode              BillingMode?
  // Descuento % (0-100) si el cliente elige pago recurrente; solo si billingMode RECURRING o BOTH
  recurringDiscountPercent Int?            @default(0)
  // Cuántas veces puede asistir en el período: null = ilimitado
  maxReservations          Int?
  maxReservationsPerDay    Int? // distribución: máx por día
  maxReservationsPerWeek   Int? // distribución: máx por semana (ej. 8/mes, máx 4/semana)
  // Ciclo de vida
  archivedAt               DateTime? // si no null, el plan está deshabilitado (no se muestra en tienda)
  sortOrder                Int             @default(0) // menor primero; orden manual del admin
  isPopular                Boolean         @default(false) // destaca con badge "Popular" en la tienda
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  center         Center              @relation(fields: [centerId], references: [id], onDelete: Cascade)
  orders         Order[]
  userPlans      UserPlan[]
  subscriptions  Subscription[]
  categoryQuotas PlanCategoryQuota[]

  @@unique([centerId, slug])
  @@index([centerId])
  @@index([centerId, archivedAt])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  MERCADOPAGO
  TRANSFER
}

model Order {
  id                      String        @id @default(cuid())
  centerId                String
  userId                  String
  planId                  String
  subscriptionId          String? // si es cuota de suscripción recurrente
  amountCents             Int
  currency                String        @default("CLP")
  status                  OrderStatus   @default(PENDING)
  paymentMethod           PaymentMethod @default(MERCADOPAGO)
  externalReference       String        @unique
  mpPreferenceId          String?
  mpPaymentId             String?
  // Transferencia bancaria (sólo cuando paymentMethod = TRANSFER)
  transferClaimedAt       DateTime?
  transferReceiptSanityId String?
  transferRejectedReason  String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  center       Center        @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([centerId])
  @@index([centerId, createdAt])
  @@index([centerId, paymentMethod, status])
  @@index([userId])
  @@index([externalReference])
  @@index([mpPaymentId])
  @@index([subscriptionId])
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
  PAYMENT_FAILED
}

model Subscription {
  id                 String             @id @default(cuid())
  centerId           String
  userId             String
  planId             String
  mpSubscriptionId   String             @unique
  mpPayerId          String?
  status             SubscriptionStatus @default(PENDING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  center    Center     @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan       @relation(fields: [planId], references: [id], onDelete: Restrict)
  userPlans UserPlan[]
  orders    Order[]

  @@index([centerId])
  @@index([userId])
  @@index([planId])
  @@index([mpSubscriptionId])
}

model MercadoPagoWebhookEvent {
  id          String   @id @default(cuid())
  centerId    String
  requestId   String
  processedAt DateTime @default(now())

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([centerId, requestId])
  @@index([centerId])
}

// ─── Preferencias de email por usuario+centro ─────────────────────────────────
model EmailPreference {
  id                 String   @id @default(cuid())
  userId             String
  centerId           String
  classReminder      Boolean  @default(true)
  spotFreed          Boolean  @default(true)
  planExpiring       Boolean  @default(true)
  reservationConfirm Boolean  @default(true)
  purchaseConfirm    Boolean  @default(true)
  lessonUnlocked     Boolean  @default(true)
  quotaExhausted     Boolean  @default(true)
  newContent         Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([userId, centerId])
  @@index([userId])
  @@index([centerId])
}

// ─── Auth Tokens ────────────────────────────────────────────────────────────
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  centerId  String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, centerId, createdAt])
  @@index([ip, createdAt])
}

// ─── Eventos (retiros, talleres, workshops) ──────────────────────────────────

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum EventTicketStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model Event {
  id          String      @id @default(cuid())
  centerId    String
  title       String
  description String?     @db.Text
  location    String?
  imageUrl    String?
  startsAt    DateTime
  endsAt      DateTime
  amountCents Int         @default(0)
  currency    String      @default("CLP")
  maxCapacity Int?
  status      EventStatus @default(PUBLISHED)
  color       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  center          Center          @relation(fields: [centerId], references: [id], onDelete: Cascade)
  tickets         EventTicket[]
  waitlistEntries WaitlistEntry[]

  @@index([centerId])
  @@index([centerId, startsAt])
}

model EventTicket {
  id            String            @id @default(cuid())
  eventId       String
  userId        String
  amountCents   Int
  quantity      Int               @default(1)
  currency      String            @default("CLP")
  status        EventTicketStatus @default(PENDING)
  paymentMethod PaymentMethod     @default(MERCADOPAGO)
  mpPaymentId   String?
  // external_reference enviado a MP al crear la preferencia inicial; el webhook
  // lo usa para mapear payment → ticket cuando no hay Order.
  externalReference String? @unique
  // Re-compra: cupos extra iniciados via "Agregar más cupos" que aún esperan
  // confirmación MP (webhook approved los suma a quantity y limpia estos
  // campos). En eventos gratuitos siempre son 0 / null (incremento directo).
  pendingAdditionQuantity          Int     @default(0)
  pendingAdditionExternalReference String? @unique
  orderId       String?
  // Transferencia bancaria (sólo cuando paymentMethod = TRANSFER)
  transferClaimedAt       DateTime?
  transferReceiptSanityId String?
  transferRejectedReason  String?
  paidAt                  DateTime?
  createdAt               DateTime          @default(now())

  event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  manualPayments ManualPayment[]

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([paymentMethod, status])
}

// ─── On Demand ────────────────────────────────────────────────────────────────

enum OnDemandContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model OnDemandCategory {
  id           String                @id @default(cuid())
  centerId     String
  name         String
  description  String?
  thumbnailUrl String?
  sortOrder    Int                   @default(0)
  status       OnDemandContentStatus @default(DRAFT)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  center    Center              @relation(fields: [centerId], references: [id], onDelete: Cascade)
  practices OnDemandPractice[]
  quotas    PlanCategoryQuota[]

  @@unique([centerId, name])
  @@index([centerId])
  @@index([centerId, status])
}

model OnDemandPractice {
  id           String                @id @default(cuid())
  categoryId   String
  name         String
  description  String?
  thumbnailUrl String?
  sortOrder    Int                   @default(0)
  status       OnDemandContentStatus @default(DRAFT)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  category OnDemandCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  lessons  OnDemandLesson[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([categoryId, status])
}

model OnDemandLesson {
  id              String                @id @default(cuid())
  practiceId      String
  title           String
  description     String?
  videoUrl        String
  promoVideoUrl   String?
  thumbnailUrl    String?
  durationMinutes Int?
  level           String?
  intensity       String?
  targetAudience  String?
  equipment       String?
  tags            String?
  sortOrder       Int                   @default(0)
  status          OnDemandContentStatus @default(DRAFT)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  practice OnDemandPractice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  unlocks  LessonUnlock[]

  @@index([practiceId])
  @@index([practiceId, status])
}

model PlanCategoryQuota {
  id         String   @id @default(cuid())
  planId     String
  categoryId String
  maxLessons Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  plan     Plan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  category OnDemandCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([planId, categoryId])
  @@index([planId])
  @@index([categoryId])
}

model LessonUnlock {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  userPlanId String
  centerId   String
  unlockedAt DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   OnDemandLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userPlan UserPlan       @relation(fields: [userPlanId], references: [id], onDelete: Cascade)
  center   Center         @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([userId, centerId])
  @@index([userPlanId])
  @@index([centerId])
}

// ─── Configuración del sitio público ─────────────────────────────────────────
model CenterSiteConfig {
  id                       String   @id @default(cuid())
  centerId                 String   @unique
  heroEyebrow              String?
  heroTitle                String?
  heroSubtitle             String?
  heroImageUrl             String?
  logoUrl                  String?
  faviconUrl               String?
  colorPrimary             String?
  colorSecondary           String?
  colorAccent              String?
  contactEmail             String?
  contactPhone             String?
  contactAddress           String?
  instagramUrl             String?
  facebookUrl              String?
  whatsappUrl              String?
  youtubeUrl               String?
  blogEnabled              Boolean  @default(false)
  blogLabel                String   @default("Blog")
  blogHeroTitle            String?
  blogHeroSubtitle         String?
  headerNavLabelHowItWorks String?
  headerNavLabelInPerson   String?
  headerNavLabelOnline     String?
  headerNavLabelContact    String?
  libraryHeroTitle         String?
  libraryHeroDescription   String?
  libraryHeroImageUrl      String?
  seoTitle                 String?
  seoDescription           String?
  heroOverlayEnabled       Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

model CenterSiteSection {
  id         String   @id @default(cuid())
  centerId   String
  sectionKey String
  title      String?
  subtitle   String?
  visible    Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  center Center                  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  items  CenterSiteSectionItem[]

  @@unique([centerId, sectionKey])
  @@index([centerId])
}

model CenterSiteSectionItem {
  id          String   @id @default(cuid())
  sectionId   String
  title       String?
  description String?
  imageUrl    String?
  linkUrl     String?
  href        String?
  userId      String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  section CenterSiteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

// ─── Página "Sobre" dedicada (bio + galería por categoría) ──────────────────
model CenterAboutPage {
  id           String   @id @default(cuid())
  centerId     String   @unique
  visible      Boolean  @default(false)
  showInHeader Boolean  @default(false)
  headerLabel  String   @default("Sobre mí")
  pageTitle    String   @default("Sobre mí")
  pageEyebrow  String?
  name         String?
  tagline      String?
  heroImageUrl String?
  bio          String?
  propuesta    String?
  ctaLabel     String   @default("Agenda tu primera clase")
  ctaHref      String   @default("/#agenda")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  center Center                 @relation(fields: [centerId], references: [id], onDelete: Cascade)
  images CenterAboutPageImage[]
}

enum AboutImageCategory {
  RETIROS
  CLASES
  ESPACIO
}

model CenterAboutPageImage {
  id        String             @id @default(cuid())
  pageId    String
  imageUrl  String
  caption   String?
  category  AboutImageCategory
  sortOrder Int                @default(0)
  visible   Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  page CenterAboutPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, category, sortOrder])
}
