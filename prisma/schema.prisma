// CuerpoRaíz — DB: Postgres (Supabase). Conexión vía DATABASE_URL.
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Tenants (centros) ─────────────────────────────────────────────────────
model Center {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Políticas del centro (tenant)
  cancelBeforeHours   Int      @default(12)  // horas antes para cancelar sin consumir clase
  maxNoShowsPerMonth  Int      @default(2)  // no-shows máximos antes de advertencia/bloqueo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     UserCenterRole[]
  liveClasses     LiveClass[]
  mercadopagoConfig CenterMercadoPagoConfig?
  plans           Plan[]
  orders          Order[]
  webhookEvents   MercadoPagoWebhookEvent[]
}

// ─── Usuarios (sin datos de infra; dominio puro en lib/domain) ──────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships UserCenterRole[]
  reservations Reservation[]
  orders     Order[]
}

// ─── Clases en vivo (por centro) ───────────────────────────────────────────
model LiveClass {
  id              String   @id @default(cuid())
  centerId        String
  title           String
  startsAt        DateTime
  durationMinutes Int      @default(60)
  maxCapacity     Int      @default(20)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  center       Center        @relation(fields: [centerId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([centerId])
  @@index([startsAt])
}

// Estados de reserva
enum ReservationStatus {
  CONFIRMED   // Confirmada
  CANCELLED   // Cancelada
  ATTENDED    // Asistió
  NO_SHOW     // No asistió
}

model Reservation {
  id         String           @id @default(cuid())
  userId     String
  liveClassId String
  status     ReservationStatus @default(CONFIRMED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClass LiveClass @relation(fields: [liveClassId], references: [id], onDelete: Cascade)

  @@unique([userId, liveClassId])
  @@index([userId])
  @@index([liveClassId])
}

// Rol por centro (multi-tenant RBAC)
enum Role {
  ADMINISTRADORA
  PROFESORA
  ALUMNA
}

model UserCenterRole {
  id        String   @id @default(cuid())
  userId    String
  centerId  String
  role      Role
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([userId, centerId])
  @@index([userId])
  @@index([centerId])
}

// ─── MercadoPago por centro (plugin activo + credenciales) ──────────────────
model CenterMercadoPagoConfig {
  id            String   @id @default(cuid())
  centerId      String   @unique
  accessToken   String
  webhookSecret String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
}

enum PlanType {
  PACK
  MEMBERSHIP
}

model Plan {
  id          String   @id @default(cuid())
  centerId    String
  name        String
  slug        String
  description String?
  amountCents Int
  currency    String   @default("CLP")
  type        PlanType
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([centerId, slug])
  @@index([centerId])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

model Order {
  id                 String      @id @default(cuid())
  centerId           String
  userId             String
  planId             String
  amountCents        Int
  currency           String      @default("CLP")
  status             OrderStatus @default(PENDING)
  externalReference  String      @unique
  mpPreferenceId     String?
  mpPaymentId        String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([centerId])
  @@index([userId])
  @@index([externalReference])
  @@index([mpPaymentId])
}

model MercadoPagoWebhookEvent {
  id          String   @id @default(cuid())
  centerId    String
  requestId   String
  processedAt DateTime @default(now())

  center Center @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([centerId, requestId])
  @@index([centerId])
}
